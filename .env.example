# ══════════════════════════════════════════════════════════════════════
# NARAD Configuration — copy this file to .env and fill in your values
# ══════════════════════════════════════════════════════════════════════

# ─── REQUIRED: Gemini API Key ──────────────────────────────────────────
# Get a free key in 2 minutes at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ─── Google Cloud (for deployment + BigQuery history storage) ──────────
# GCP_PROJECT_ID must be a REAL project you own for BigQuery to activate.
# Without a real project + credentials, NARAD automatically falls back to
# in-memory history storage — nothing breaks, you just lose persistence
# across restarts and long-term trend queries.
#
# To enable BigQuery locally:
#   1. Set GCP_PROJECT_ID below to an actual GCP project ID
#   2. Run: gcloud auth application-default login
#   3. Ensure the BigQuery API is enabled: gcloud services enable bigquery.googleapis.com
# (Cloud Run deployment via deploy.sh handles all of this automatically.)
GCP_PROJECT_ID=your-real-gcp-project-id
GCP_REGION=us-central1
BIGQUERY_DATASET=narad_city_data

# ─── OPTIONAL: Live data API keys (system works with realistic ─────────
# simulation if these are omitted — great for demos without setup) ─────
OPENWEATHER_API_KEY=
OPENAQ_API_KEY=
NEWS_API_KEY=

# Google Maps API key — enables REAL live traffic congestion data via
# Distance Matrix API (departure_time=now). Get one at:
# https://console.cloud.google.com/google/maps-apis/credentials
# Without this, traffic falls back to realistic time-of-day simulation.
GOOGLE_MAPS_API_KEY=

# ─── City Configuration ─────────────────────────────────────────────────
DEFAULT_CITY=Hyderabad
DEFAULT_LAT=17.3850
DEFAULT_LNG=78.4867

# ─── Application Behavior ───────────────────────────────────────────────
DEBUG=false
PORT=8080
PARLIAMENT_INTERVAL=60
DATA_REFRESH_INTERVAL=30

# ─── RAPIDS / GPU ────────────────────────────────────────────────────────
USE_GPU=auto
SCENARIO_COUNT=1000

# ─── Security ────────────────────────────────────────────────────────────
# REQUIRED for any write operation (hospital reports, parliament trigger) to
# work at all — these endpoints FAIL CLOSED (refuse all requests) if this is
# unset, rather than silently allowing unauthenticated access.
#
# Generate a strong random value, e.g.: openssl rand -hex 24
# For local dev, any string works. In production (deploy.sh), a random key is
# generated automatically and stored in Secret Manager — you don't set this
# by hand when deploying via deploy.sh.
NARAD_ADMIN_API_KEY=

# Comma-separated origins allowed to call this API cross-origin. Does NOT
# affect the dashboard calling its own backend (same-origin requests aren't
# subject to CORS at all) — this only matters if some other website tries to
# call the API from a visitor's browser. Defaults to local dev only.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080
