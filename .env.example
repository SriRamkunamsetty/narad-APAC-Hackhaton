# ══════════════════════════════════════════════════════════════════════
# NARAD Configuration — copy this file to .env and fill in your values
# ══════════════════════════════════════════════════════════════════════

# ─── REQUIRED: Gemini API Key ──────────────────────────────────────────
# Get a free key in 2 minutes at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ─── Google Cloud (for deployment) ─────────────────────────────────────
GCP_PROJECT_ID=narad-city-ai
GCP_REGION=us-central1
BIGQUERY_DATASET=narad_city_data

# ─── OPTIONAL: Live data API keys (system works with realistic ─────────
# simulation if these are omitted — great for demos without setup) ─────
OPENWEATHER_API_KEY=
OPENAQ_API_KEY=
NEWS_API_KEY=

# Google Maps API key — enables REAL live traffic congestion data via
# Distance Matrix API (departure_time=now). Get one at:
# https://console.cloud.google.com/google/maps-apis/credentials
# Without this, traffic falls back to realistic time-of-day simulation.
GOOGLE_MAPS_API_KEY=

# ─── City Configuration ─────────────────────────────────────────────────
DEFAULT_CITY=Hyderabad
DEFAULT_LAT=17.3850
DEFAULT_LNG=78.4867

# ─── Application Behavior ───────────────────────────────────────────────
DEBUG=false
PORT=8080
PARLIAMENT_INTERVAL=60
DATA_REFRESH_INTERVAL=30

# ─── RAPIDS / GPU ────────────────────────────────────────────────────────
USE_GPU=auto
SCENARIO_COUNT=1000
